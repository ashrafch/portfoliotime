# =============================================
# PortfolioTime — variabili d'ambiente
# Copia questo file in .env e compila i valori
# =============================================

# --- Database (PostgreSQL + TimescaleDB) ---
# Avviato da docker-compose. Non modificare host/porta in locale.
DATABASE_URL=postgresql://portfoliotime:portfoliotime@localhost:5432/portfoliotime

# --- Cache e code broker (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333

# --- Anthropic Claude (obbligatorio) ---
# Ottieni su: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-INSERISCI_LA_TUA_CHIAVE_QUI

# --- FRED (Federal Reserve Economic Data) ---
# Gratuito su: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=INSERISCI_LA_TUA_FRED_KEY_QUI

# --- CoinGecko ---
# Lascia vuoto per il piano gratuito (rate limited)
# Oppure inserisci la Demo API key da: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# --- Autenticazione JWT ---
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERA_UNA_STRINGA_RANDOM_DA_32_CARATTERI

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
